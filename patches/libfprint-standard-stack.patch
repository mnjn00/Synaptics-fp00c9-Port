+static gboolean
+find_print_by_template_id (GPtrArray *prints, const guint8 *template_id, guint *index_out)
+{
+  guint i;
+
+  for (i = 0; i < prints->len; i++)
+    {
+      g_autoptr (GError) error = NULL;
+      Db2Id candidate;
+
+      if (!get_template_id_from_fp_print (g_ptr_array_index (prints, i), candidate, &error))
+        continue;
+
+      if (memcmp (candidate, template_id, sizeof (Db2Id)) == 0)
+        {
+          if (index_out)
+            *index_out = i;
+          return TRUE;
+        }
+    }
+
+  return FALSE;
+}
