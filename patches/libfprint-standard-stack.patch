+static char *
+get_persistent_data_descriptor (FpDevice *dev)
+{
+  return g_strdup_printf ("%s/%s/persistent-data",
+                          fp_device_get_driver (dev),
+                          fp_device_get_device_id (dev));
+}
+
+int
+persistent_data_save (FpDevice *dev)
+{
+  g_autoptr (GVariantDict) dict = NULL;
+  g_autoptr (GVariant) persistent_data = NULL;
+  g_autofree gchar *descr = NULL;
+
+  g_object_get (dev, "fpi-persistent-data", &persistent_data, NULL);
+  if (!persistent_data)
+    return 0;
+
+  dict = load_data ();
+  descr = get_persistent_data_descriptor (dev);
+  g_variant_dict_insert_value (dict, descr, persistent_data);
+
+  return save_data (g_variant_dict_end (dict));
+}
+
+int
+persistent_data_load (FpDevice *dev)
+{
+  g_autoptr (GVariantDict) dict = NULL;
+  g_autoptr (GVariant) persistent_data = NULL;
+  g_autofree gchar *descr = NULL;
+
+  dict = load_data ();
+  descr = get_persistent_data_descriptor (dev);
+  persistent_data = g_variant_dict_lookup_value (dict, descr, NULL);
+
+  if (!persistent_data)
+    return -ENOENT;
+
+  g_object_set (dev, "fpi-persistent-data", persistent_data, NULL);
+  return 0;
+}
