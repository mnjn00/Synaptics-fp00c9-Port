diff --git a/pydrv/tudor/sensor/iota.py b/pydrv/tudor/sensor/iota.py
index 05a4401..986b76b 100644
--- a/pydrv/tudor/sensor/iota.py
+++ b/pydrv/tudor/sensor/iota.py
@@ -120,8 +120,13 @@ class WbfParamIOTA(PackedIOTA):
     def __init__(self, iota_id: int, data: bytes):
         super().__init__(iota_id, data)
 
-        # FIXME: different than original
-        ver, self.param = struct.unpack("<xxxBIxxxxxxxx", self.payload)
+        # Some sensors expose an 8-byte payload here, others 16 bytes.
+        if len(self.payload) == 8:
+            ver, self.param = struct.unpack("<xxxBI", self.payload)
+        elif len(self.payload) == 16:
+            ver, self.param = struct.unpack("<xxxBIxxxxxxxx", self.payload)
+        else:
+            raise ValueError(f"Unexpected WBF IOTA payload length: {len(self.payload)} bytes: {self.payload.hex()}")
         assert ver == 1
 
     @staticmethod
