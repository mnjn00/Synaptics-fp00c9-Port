+static gboolean
+template_id_to_hex (FpPrint *print, gchar **hex_out)
+{
+  g_autoptr(GVariant) fpi_data = NULL;
+  g_autoptr(GVariant) tid_var = NULL;
+  const guint8 *tid = NULL;
+  gsize tid_len = 0;
+  GString *hex;
+  guint i;
+  guint8 finger_id = 0;
+
+  g_object_get (print, "fpi-data", &fpi_data, NULL);
+  if (!fpi_data || !g_variant_check_format_string (fpi_data, "(y@ay@ay)", FALSE))
+    return FALSE;
+
+  g_variant_get (fpi_data, "(y@ay@ay)", &finger_id, &tid_var, NULL);
+  tid = g_variant_get_fixed_array (tid_var, &tid_len, 1);
+  if (!tid || tid_len == 0)
+    return FALSE;
+
+  hex = g_string_sized_new (tid_len * 2);
+  for (i = 0; i < tid_len; i++)
+    g_string_append_printf (hex, "%02x", tid[i]);
+
+  *hex_out = g_string_free (hex, FALSE);
+  return TRUE;
+}
